      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Nome\": \"Nuovo\",\n  \"Cognome\": \"Dipendente\",\n  \"Email\": \"nuovo.dipendente@azienda.com\",\n  \"Password\": \"password123\",\n  \"Ruolo\": \"dipendente\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/utenti/register",
              "host": ["http://localhost:3001"],
              "path": ["api", "utenti", "register"]
            }
          }
        },
        {
          "name": "Login (Referente)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Email\": \"marco.rossi@azienda.com\",\n  \"Password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/utenti/login",
              "host": ["http://localhost:3001"],
              "path": ["api", "utenti", "login"]
            }
          }
        },
        {
          "name": "Login (Dipendente)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Email\": \"laura.bianchi@azienda.com\",\n  \"Password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/utenti/login",
              "host": ["http://localhost:3001"],
              "path": ["api", "utenti", "login"]
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "http://localhost:3001/api/utenti/me",
              "host": ["http://localhost:3001"],
              "path": ["api", "utenti", "me"]
            }
          }
        }
